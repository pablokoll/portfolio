---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getProjectsData } from '../../lib/get-projects-data';
import type { ProjectDetail } from '../../lib/types';

export function getStaticPaths() {
  const projects = getProjectsData();
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

interface Props {
  project: ProjectDetail;
}

const { project } = Astro.props;

const badgeColor = project.badge === 'freelance' ? 'green'
  : project.badge === 'personal' ? 'sky'
  : project.badge === 'open-source' ? 'mauve'
  : 'muted';

const allImages = [project.image, ...(project.gallery ?? [])];
---

<Layout
  title={`${project.name} — Pablo Koll`}
  description={project.description}
>
  <Navbar />

  <main class="project-detail-main">
    <div class="project-detail-container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/#projects" class="breadcrumb-link">projects</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{project.id}</span>
      </nav>

      <!-- Hero Image -->
      <div class="hero-image-wrap">
        <img
          src={project.image}
          alt={`${project.name} screenshot`}
          class="hero-image"
          data-lightbox-index="0"
        />
      </div>

      <!-- Project Header -->
      <div class="project-header">
        <div class="project-title-row">
          <h1 class="project-title">{project.name}</h1>
          {project.year && <span class="project-year">{project.year}</span>}
        </div>
        <div class="project-badges">
          {project.badge && (
            <span class={`project-badge project-badge--${badgeColor}`}>{project.badge}</span>
          )}
          {project.github && (
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-badge project-badge--link">
              github
            </a>
          )}
          {project.live && (
            <a href={project.live} target="_blank" rel="noopener noreferrer" class="project-badge project-badge--link">
              ↗ live
            </a>
          )}
        </div>
      </div>

      <!-- Short Description -->
      <p class="project-description">{project.description}</p>

      <!-- Stack -->
      <div class="project-stack">
        {project.stack.map((tech) => (
          <span class="project-tag">{tech}</span>
        ))}
      </div>

      <!-- Long Description -->
      <div class="long-description">
        <section class="ld-section">
          <h2 class="ld-label">// problem</h2>
          <p class="ld-body">{project.longDescription.problem}</p>
        </section>
        <section class="ld-section">
          <h2 class="ld-label">// approach</h2>
          <p class="ld-body">{project.longDescription.approach}</p>
        </section>
        <section class="ld-section">
          <h2 class="ld-label">// outcome</h2>
          <p class="ld-body">{project.longDescription.outcome}</p>
        </section>
      </div>

      <!-- Gallery -->
      {project.gallery && project.gallery.length > 0 && (
        <div class="gallery">
          <h2 class="ld-label">// screenshots</h2>
          <div class="gallery-grid">
            {project.gallery.map((src, i) => (
              <img
                src={src}
                alt={`${project.name} screenshot ${i + 1}`}
                class="gallery-thumb"
                data-lightbox-index={i + 1}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Back Link -->
      <a href="/#projects" class="back-link">← back_to_projects()</a>

    </div>
  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">✕</button>
    {allImages.length > 1 && (
      <>
        <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous image">‹</button>
        <button class="lightbox-next" id="lightbox-next" aria-label="Next image">›</button>
      </>
    )}
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <img id="lightbox-img" class="lightbox-img" src="" alt="" />
  </div>

</Layout>

<script define:vars={{ allImages }}>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');
  const backdrop = document.getElementById('lightbox-backdrop');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let currentIndex = 0;

  function openLightbox(index) {
    currentIndex = index;
    lightboxImg.src = allImages[currentIndex];
    lightbox.setAttribute('aria-hidden', 'false');
    lightbox.classList.add('lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    lightbox.classList.remove('lightbox--open');
    document.body.style.overflow = '';
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % allImages.length;
    lightboxImg.src = allImages[currentIndex];
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + allImages.length) % allImages.length;
    lightboxImg.src = allImages[currentIndex];
  }

  document.querySelectorAll('[data-lightbox-index]').forEach((el) => {
    el.addEventListener('click', () => {
      openLightbox(parseInt(el.getAttribute('data-lightbox-index'), 10));
    });
  });

  closeBtn?.addEventListener('click', closeLightbox);
  backdrop?.addEventListener('click', closeLightbox);
  prevBtn?.addEventListener('click', showPrev);
  nextBtn?.addEventListener('click', showNext);

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('lightbox--open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'ArrowLeft') showPrev();
  });
</script>

<style>
  .project-detail-main {
    padding-top: 80px;
    padding-bottom: 80px;
    min-height: 100vh;
  }

  .project-detail-container {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg-muted);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .breadcrumb-link {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--duration-2) var(--ease);
  }

  .breadcrumb-link:hover {
    color: var(--pk-mauve);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-current {
    color: var(--fg);
  }

  .hero-image-wrap {
    width: 100%;
    margin-bottom: 32px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    cursor: zoom-in;
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity var(--duration-2) var(--ease);
  }

  .hero-image:hover {
    opacity: 0.9;
  }

  .project-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .project-title {
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    color: var(--fg);
    margin: 0;
    line-height: 1.15;
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--fg-muted);
    flex-shrink: 0;
  }

  .project-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 99px;
    background: transparent;
    text-decoration: none;
  }

  .project-badge--green { color: var(--pk-green); border: 1px solid var(--pk-green); }
  .project-badge--sky   { color: var(--pk-sky);   border: 1px solid var(--pk-sky); }
  .project-badge--mauve { color: var(--pk-mauve); border: 1px solid var(--pk-mauve); }
  .project-badge--muted { color: var(--fg-secondary); border: 1px solid var(--border); }
  .project-badge--link  {
    color: var(--fg-muted);
    border: 1px solid var(--border);
    transition: color var(--duration-2) var(--ease), border-color var(--duration-2) var(--ease);
  }
  .project-badge--link:hover {
    color: var(--pk-mauve);
    border-color: var(--pk-mauve);
  }

  .project-description {
    font-size: 15px;
    color: var(--fg-secondary);
    line-height: 1.65;
    margin: 24px 0 0;
    max-width: 640px;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 20px;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 3px 8px;
    border-radius: 6px;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
  }

  .long-description {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .ld-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: 0 0 12px;
  }

  .ld-body {
    font-size: 15px;
    color: var(--fg);
    line-height: 1.7;
    margin: 0;
    max-width: 640px;
  }

  .gallery {
    margin-top: 48px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 16px;
  }

  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }

  .gallery-thumb {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    cursor: zoom-in;
    transition: filter var(--duration-2) var(--ease);
  }

  .gallery-thumb:hover {
    filter: brightness(0.85);
  }

  .back-link {
    display: inline-block;
    margin-top: 64px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--duration-2) var(--ease);
  }

  .back-link:hover {
    color: var(--pk-mauve);
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .lightbox--open {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: zoom-out;
  }

  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 18px;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-2) var(--ease), border-color var(--duration-2) var(--ease);
  }

  .lightbox-close:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 28px;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-2) var(--ease), border-color var(--duration-2) var(--ease);
  }

  .lightbox-prev { left: 20px; }
  .lightbox-next { right: 20px; }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
  }
</style>
