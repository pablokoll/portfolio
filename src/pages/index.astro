---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import KeyboardNav from '../components/KeyboardNav.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import SkillCard from '../components/SkillCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import LearningCard from '../components/LearningCard.astro';
import Footer from '../components/Footer.astro';
import { getPortfolioData } from '../lib/get-portfolio-data';

const data = await getPortfolioData();
---

<Layout
  title={data.meta.title}
  description={data.meta.description}
  ogImage={data.meta.ogImage}
  url={data.meta.url}
>
  <!-- Skip to content (accessibility) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-ctp-blue focus:text-ctp-base focus:rounded focus:text-sm"
  >
    Skip to content
  </a>

  <ThemeToggle />
  <KeyboardNav />

  <main id="main-content" role="main">
    <!-- Hero Section -->
    <Hero data={data.hero} />

    <!-- Experience Section -->
    <Section
      id="experience"
      title={data.experience.title}
      subtitle={data.experience.subtitle}
    >
      <div class="space-y-6" role="list">
        {data.experience.items.map((exp) => (
          <div role="listitem">
            <ExperienceCard experience={exp} />
          </div>
        ))}
      </div>
    </Section>

    <!-- Skills Section -->
    <Section
      id="skills"
      title={data.skills.title}
      subtitle={data.skills.subtitle}
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {data.skills.items.map((skill) => (
          <div role="listitem">
            <SkillCard skill={skill} />
          </div>
        ))}
      </div>
    </Section>

    <!-- Projects Section -->
    <Section
      id="projects"
      title={data.projects.title}
      subtitle={data.projects.subtitle}
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {data.projects.items.map((project) => (
          <div role="listitem">
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </Section>

    <!-- Learning Section -->
    <Section
      id="learning"
      title={data.learning.title}
      subtitle={data.learning.subtitle}
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {data.learning.items.map((item) => (
          <div role="listitem">
            <LearningCard item={item} />
          </div>
        ))}
      </div>
    </Section>
  </main>

  <!-- Footer -->
  <Footer data={data.footer} />
</Layout>
