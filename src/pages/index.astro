---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import KeyboardNav from '../components/KeyboardNav.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import LearningCard from '../components/LearningCard.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getPortfolioData } from '../lib/get-portfolio-data';

const data = await getPortfolioData();
---

<Layout
  title={data.meta.title}
  description={data.meta.description}
  ogImage={data.meta.ogImage}
  url={data.meta.url}
>
  <!-- Skip to content (accessibility) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-ctp-blue focus:text-ctp-base focus:rounded focus:text-sm"
  >
    Skip to content
  </a>

  <Navbar />
  <KeyboardNav />

  <main id="main-content" role="main" class="main-content">
    <!-- Hero Section -->
    <Hero data={data.hero} />

    <!-- Projects Section — 01 -->
    <Section
      id="projects"
      index={1}
      title={data.projects.title}
      subtitle={data.projects.subtitle}
      class="section--first"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch" role="list">
        {data.projects.items.map((project, i) => (
          <div role="listitem" class="flex">
            <ProjectCard project={project} index={i + 1} />
          </div>
        ))}
      </div>
    </Section>

    <!-- Experience Section — 02 -->
    <Section
      id="experience"
      index={2}
      title={data.experience.title}
      subtitle={data.experience.subtitle}
    >
      <div role="list">
        {data.experience.items.map((exp) => (
          <ExperienceCard experience={exp} />
        ))}
      </div>
    </Section>

    <!-- Skills Section — HIDDEN (to be redesigned) -->
    {/* <Section
      id="skills"
      index={3}
      title={data.skills.title}
      subtitle={data.skills.subtitle}
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {data.skills.items.map((skill) => (
          <div role="listitem">
            <SkillCard skill={skill} />
          </div>
        ))}
      </div>
    </Section> */}

    <!-- Learning Section — 03 -->
    <Section
      id="learning"
      index={3}
      title={data.learning.title}
      subtitle={data.learning.subtitle}
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {data.learning.items.map((item) => (
          <div role="listitem">
            <LearningCard item={item} />
          </div>
        ))}
      </div>
    </Section>

    <!-- Contact Section — 04 -->
    <Section
      id="contact"
      index={4}
      title="Contact"
      titleHtml={`Let's <a href="mailto:${data.contact.email}" class="contact-title-link">talk to</a> build something good.`}
      subtitle="// contact to drink a coffee."
      class="section--contact"
    >
      <Contact data={data.contact} />
    </Section>
  </main>

  <!-- Footer -->
  <Footer data={data.footer} />
</Layout>

<style>
  .main-content {
    padding-top: 56px;
  }

  @media (max-width: 767px) {
    .main-content {
      padding-top: 52px;
    }
  }
</style>
