---
import type { ExperienceItem } from '../lib/types';

interface Props {
  experience: ExperienceItem;
}

const { experience } = Astro.props;
---

<article class="p-6 md:p-8 bg-ctp-surface0 rounded card-hover">
  <!-- Header: Role + Date -->
  <header class="mb-5">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-1">
      <h3 class="text-lg md:text-xl font-semibold text-ctp-text">
        {experience.role}
      </h3>
      <span class:list={[
        'text-sm font-mono',
        experience.isCurrent ? 'text-ctp-green' : 'text-ctp-overlay0'
      ]}>
        {experience.period}
      </span>
    </div>
    <p class="text-sm text-ctp-overlay2">{experience.company}</p>
  </header>

  <!-- Description -->
  <p class="text-sm text-ctp-subtext1 leading-relaxed mb-5">
    {experience.description}
  </p>

  <!-- Stack Tags -->
  <footer class="flex flex-wrap gap-2">
    {experience.stack.map((tech) => (
      <span class="px-3 py-1.5 text-xs font-medium bg-ctp-surface1 text-ctp-green rounded">
        {tech}
      </span>
    ))}
  </footer>
</article>
