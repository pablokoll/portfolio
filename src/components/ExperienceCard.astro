---
import type { ExperienceItem } from '../lib/types';

interface Props {
  experience: ExperienceItem;
}

const { experience } = Astro.props;
---

<article class="exp-entry">
  <div class="exp-header">
    <div class="exp-header-left">
      <h3 class="exp-role">{experience.role}</h3>
      <p class="exp-company">{experience.company}</p>
    </div>
    <div class="exp-header-right">
      <div class:list={['exp-period', experience.isCurrent ? 'exp-period--current' : '']}>
        {experience.isCurrent && <span class="exp-dot"></span>}
        {experience.period}
      </div>
      <span class="exp-badge">{experience.type}</span>
    </div>
  </div>

  {experience.bulletsHtml ? (
    <ul class="exp-bullets">
      {experience.bulletsHtml.map((bullet) => (
        <li set:html={bullet} />
      ))}
    </ul>
  ) : (
    <p class="exp-description">{experience.description}</p>
  )}
</article>

<style>
  .exp-entry {
    padding: 14px 0 20px;
    border-bottom: none;
    background-image: repeating-linear-gradient(to right, var(--border) 0, var(--border) 12px, transparent 12px, transparent 20px);
    background-position: bottom;
    background-size: 100% 1px;
    background-repeat: no-repeat;
  }

  .exp-entry:last-child {
    background-image: none;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  .exp-header-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .exp-header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }

  .exp-role {
    font-size: clamp(16px, 2vw, 19px);
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    line-height: 1.3;
  }

  .exp-company {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pk-steel);
    margin: 0;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .exp-period--current {
    color: var(--pk-green);
  }

  .exp-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 99px;
    background: var(--pk-green);
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .exp-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 99px;
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .exp-bullets li {
    font-size: 14px;
    color: var(--fg-secondary);
    line-height: 1.6;
    padding-left: 16px;
    position: relative;
  }

  .exp-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--fg-muted);
  }

  .exp-bullets li :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }

  .exp-bullets li :global(em) {
    color: var(--pk-steel);
    font-style: normal;
  }

  .exp-description {
    font-size: 14px;
    color: var(--fg-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 820px;
  }

  @media (max-width: 600px) {
    .exp-header {
      flex-direction: column;
      gap: 8px;
    }

    .exp-header-right {
      align-items: flex-start;
      flex-direction: row;
      gap: 12px;
    }
  }
</style>
