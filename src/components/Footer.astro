---
import type { Footer as FooterType } from '../lib/types';

interface Props {
  data: FooterType;
}

const { data } = Astro.props;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-divider"></div>
    <div class="footer-row">
      <span class="footer-brand">
        <span class="footer-prompt">~</span>{data.brand.name}<span class="footer-cursor" id="footer-cursor"></span>
      </span>
      <span class="footer-tagline">{data.tagline}</span>
      <span class="footer-location">Madrid, Spain · <span class="footer-year">2026</span></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 0 64px 48px;
    max-width: 1120px;
    margin: 0 auto;
  }

  .footer-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 24px;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .footer-prompt {
    color: var(--pk-steel);
    margin-right: 2px;
  }

  .footer-cursor {
    display: inline-block;
    width: 0.12em;
    height: 1em;
    background: var(--pk-steel);
    vertical-align: -0.1em;
    margin-left: 2px;
  }

  .footer-tagline {
    text-align: center;
    flex: 1;
    padding: 0 24px;
    font-weight: 700;
  }

  .footer-location {
    text-align: right;
  }

  .footer-year {
    color: var(--pk-steel);
  }

  @media (max-width: 720px) {
    .footer {
      padding: 0 24px 40px;
    }

    .footer-row {
      flex-wrap: wrap;
      gap: 6px 16px;
    }

    .footer-tagline {
      padding: 0;
      text-align: left;
      flex: 0 1 auto;
    }

    .footer-location {
      text-align: left;
    }
  }

  @media (max-width: 510px) {
    .footer-row {
      flex-direction: column;
      gap: 6px;
      align-items: center;
    }
  }
</style>

<script>
  const cursor = document.getElementById('footer-cursor');
  if (cursor) {
    let visible = true;
    setInterval(() => {
      visible = !visible;
      cursor.style.opacity = visible ? '1' : '0';
    }, 1000);
  }
</script>
