---
import type { LearningItem } from '../lib/types';
import Icon from './Icon.astro';

interface Props {
  item: LearningItem;
}

const { item } = Astro.props;

const iconColorVar = `var(--${item.iconColor})`;
const badgeColorVar = `var(--${item.badgeColor})`;
const isSolid = item.badge === 'COMPLETE';
---

<article class="learning-card card card-hover">
  <!-- Top row: icon + title | badge -->
  <div class="learning-header">
    <div class="learning-title-row">
      <span class="learning-icon-wrap" style={`--icon-color: ${iconColorVar}`}>
        <Icon name={item.icon} class="learning-icon" />
      </span>
      <h3 class="learning-name">{item.name}</h3>
    </div>
    <span
      class:list={['learning-badge', isSolid ? 'learning-badge--solid' : 'learning-badge--outline']}
      style={isSolid
        ? `background: ${badgeColorVar}; border-color: ${badgeColorVar};`
        : `color: ${badgeColorVar}; border-color: ${badgeColorVar};`}
    >
      {item.badge}
    </span>
  </div>

  <!-- Description -->
  <p class="learning-description">{item.description}</p>

  <!-- Progress -->
  <div class="learning-progress">
    <span class="learning-progress-label">{item.progressComment}</span>
    <div class="learning-bar-track">
      <div
        class="learning-bar-fill"
        style={`width: ${item.progressPercent}%; background: ${iconColorVar};`}
      ></div>
    </div>
  </div>
</article>

<style>
  .learning-card {
    padding: 20px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .learning-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .learning-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .learning-icon-wrap {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--bg-surface);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--icon-color, var(--pk-sky));
  }

  .learning-icon {
    width: 16px;
    height: 16px;
  }

  .learning-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .learning-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 99px;
    border: 1px solid transparent;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .learning-badge--outline {
    background: transparent;
  }

  .learning-badge--solid {
    color: var(--bg);
  }

  .learning-description {
    font-size: 13px;
    color: var(--fg-secondary);
    line-height: 1.55;
    margin: 0 0 16px;
    flex-grow: 1;
  }

  .learning-progress {
    margin-top: auto;
  }

  .learning-progress-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    font-style: italic;
    margin-bottom: 6px;
  }

  .learning-bar-track {
    height: 6px;
    background: var(--bg-surface);
    border-radius: 99px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .learning-bar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 600ms ease;
  }
</style>
