---
import type { Contact } from '../lib/types';

interface Props {
  data: Contact;
}

const { data } = Astro.props;
---

<div class="contact-wrap">
  <p class="contact-paragraph" set:html={data.paragraph} />

  <button
    type="button"
    class="contact-email"
    data-tooltip='copy_to_clipboard()'
    data-email={data.email}
    onclick="handleEmailCopy(this)"
  >
    {data.email}
  </button>

  <div class="contact-socials">
    {data.links.filter(l => l.url).map((link) => (
      <a
        href={link.url!}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-social-link"
      >
        <span class="contact-social-platform">{link.platform}:</span>
        <span class="contact-social-handle">{link.handle}</span>
      </a>
    ))}
  </div>
</div>

<!-- Toast -->
<div id="contact-toast" class="contact-toast" aria-live="polite">// email copied</div>

<style>
  :global(.section--contact .section-title) {
    font-style: italic;
  }

  :global(.section--contact .section-title em) {
    font-style: italic;
    color: var(--pk-steel);
  }

  :global(.section--contact .section-title .contact-title-link) {
    color: var(--pk-steel);
    font-style: italic;
    text-decoration: none;
    transition: opacity var(--duration-2) var(--ease);
  }

  :global(.section--contact .section-title .contact-title-link:hover) {
    opacity: 0.75;
  }

  .contact-wrap {
    display: flex;
    flex-direction: column;
    max-width: 640px;
  }

  .contact-paragraph {
    font-size: 15px;
    color: var(--fg-secondary);
    line-height: 1.65;
    margin: 0 0 40px;
    max-width: 520px;
  }

  .contact-paragraph :global(strong) {
    color: var(--pk-green);
    font-weight: 600;
  }

  .contact-paragraph :global(em) {
    color: var(--pk-steel);
    font-style: normal;
  }

  .contact-email {
    font-family: var(--font-mono);
    font-size: clamp(18px, 2.5vw, 28px);
    font-style: italic;
    color: var(--pk-steel);
    background: transparent;
    border: none;
    padding: 0;
    letter-spacing: -0.02em;
    cursor: pointer;
    text-align: left;
    display: inline-block;
    width: fit-content;
    text-decoration: underline;
    text-decoration-color: var(--pk-steel);
    text-underline-offset: 4px;
    margin-bottom: 48px;
    position: relative;
    transition: opacity var(--duration-2) var(--ease);
  }

  .contact-email:hover {
    opacity: 0.7;
  }

  .contact-email[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-2) var(--ease);
  }

  .contact-email[data-tooltip]:hover::after {
    opacity: 1;
  }

  .contact-socials {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .contact-social-link {
    display: flex;
    align-items: baseline;
    gap: 6px;
    text-decoration: none;
    transition: opacity var(--duration-2) var(--ease);
  }

  .contact-social-link:hover {
    opacity: 0.7;
  }

  .contact-social-platform {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pk-steel);
  }

  .contact-social-handle {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg-muted);
  }

  .contact-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 8px 16px;
    border-radius: 6px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 200ms ease, transform 200ms ease;
    pointer-events: none;
    z-index: 100;
  }

  .contact-toast.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function handleEmailCopy(btn: HTMLButtonElement) {
    const email = btn.dataset.email;
    if (!email) return;
    navigator.clipboard.writeText(email).then(() => {
      const toast = document.getElementById('contact-toast');
      if (!toast) return;
      toast.classList.add('visible');
      setTimeout(() => toast.classList.remove('visible'), 2000);
    });
  }
  (window as any).handleEmailCopy = handleEmailCopy;
</script>
