---
// Vim-style keyboard navigation
// j/k = scroll down/up
// gg = top, G = bottom
// 1-5 = jump to sections
// ? = toggle help overlay
---

<!-- Help overlay -->
<div id="kb-help" class="kb-backdrop hidden" role="dialog" aria-label="Keyboard shortcuts">
  <div class="kb-panel">
    <div class="kb-header">
      <span class="kb-title">:help keyboard</span>
      <span class="kb-hint">press ? or Esc to close</span>
    </div>

    <div class="kb-body">
      <div class="kb-group">
        <p class="kb-group-label">// navigation</p>
        <div class="kb-grid">
          <kbd class="kb-key">j / k</kbd><span class="kb-desc">scroll down / up</span>
          <kbd class="kb-key">d / u</kbd><span class="kb-desc">half page down / up</span>
          <kbd class="kb-key">gg</kbd><span class="kb-desc">go to top</span>
          <kbd class="kb-key">G</kbd><span class="kb-desc">go to bottom</span>
        </div>
      </div>

      <div class="kb-group">
        <p class="kb-group-label">// sections</p>
        <div class="kb-grid">
          <kbd class="kb-key">0</kbd><span class="kb-desc">about</span>
          <kbd class="kb-key">1</kbd><span class="kb-desc">featured_projects</span>
          <kbd class="kb-key">2</kbd><span class="kb-desc">work_experience</span>
          <kbd class="kb-key">3</kbd><span class="kb-desc">current_focus</span>
          <kbd class="kb-key">4</kbd><span class="kb-desc">contact</span>
        </div>
      </div>

      <div class="kb-group">
        <p class="kb-group-label">// actions</p>
        <div class="kb-grid">
          <kbd class="kb-key">t</kbd><span class="kb-desc">toggle theme</span>
          <kbd class="kb-key">?</kbd><span class="kb-desc">toggle this help</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Current mode indicator -->
<div id="kb-indicator" class="kb-indicator" aria-hidden="true">
  <span id="kb-indicator-text">NORMAL</span>
</div>

<style>
  .kb-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(var(--bg-rgb), 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kb-backdrop.hidden {
    display: none;
  }

  .kb-panel {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    width: 100%;
    max-width: 420px;
    margin: 0 16px;
    font-family: var(--font-mono);
  }

  .kb-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .kb-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--fg);
  }

  .kb-hint {
    font-size: 11px;
    color: var(--fg-muted);
  }

  .kb-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .kb-group-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--pk-sky);
    margin: 0 0 10px;
    letter-spacing: 0.04em;
  }

  .kb-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 20px;
    align-items: center;
  }

  .kb-key {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--pk-green);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 4px;
    white-space: nowrap;
    font-style: normal;
  }

  .kb-desc {
    font-size: 12px;
    color: var(--fg-muted);
  }

  .kb-indicator {
    position: fixed;
    bottom: 16px;
    left: 16px;
    z-index: 50;
    padding: 4px 10px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .kb-indicator.opacity-100 {
    opacity: 1;
  }
</style>

<script>
  const sections = ['experience', 'skills', 'projects', 'learning', 'contact'];
  const helpOverlay = document.getElementById('kb-help');
  const indicator = document.getElementById('kb-indicator');
  const indicatorText = document.getElementById('kb-indicator-text');

  // Vimium-style smooth scroller
  const SCROLL_STEP = 60;
  const HALF_PAGE = Math.floor(window.innerHeight / 2);
  const MIN_CALIBRATION = 0.5;
  const MAX_CALIBRATION = 1.6;
  const CALIBRATION_BOUNDARY = 150;

  let gPressed = false;
  let gTimeout: ReturnType<typeof setTimeout> | null = null;
  let indicatorTimeout: ReturnType<typeof setTimeout> | null = null;

  // Scroller state
  let scrollTime = 0;
  let scrollKeyDown: string | null = null;

  function smoothScroll(amount: number, continuous: boolean = true) {
    const sign = Math.sign(amount);
    const absAmount = Math.abs(amount);
    const duration = Math.max(100, 20 * Math.log(absAmount));
    const activationTime = ++scrollTime;

    const keyIsStillDown = () =>
      scrollTime === activationTime && scrollKeyDown != null;

    let totalDelta = 0;
    let totalElapsed = 0;
    let calibration = 1.0;
    let prevTs: number | null = null;

    function animate(ts: number) {
      if (prevTs == null) { prevTs = ts; }
      if (ts === prevTs) { requestAnimationFrame(animate); return; }

      const elapsed = ts - prevTs;
      totalElapsed += elapsed;
      prevTs = ts;

      // Calibration for held keys (after 75ms)
      if (
        keyIsStillDown() && totalElapsed >= 75 &&
        calibration >= MIN_CALIBRATION && calibration <= MAX_CALIBRATION
      ) {
        if (1.05 * calibration * absAmount < CALIBRATION_BOUNDARY) {
          calibration *= 1.05;
        }
        if (CALIBRATION_BOUNDARY < 0.95 * calibration * absAmount) {
          calibration *= 0.95;
        }
      }

      let delta = Math.ceil(absAmount * (elapsed / duration) * calibration);

      // Clamp to avoid overshoot on discrete presses
      if (!keyIsStillDown()) {
        delta = Math.max(0, Math.min(delta, absAmount - totalDelta));
      }

      if (delta > 0) {
        window.scrollBy({ top: sign * delta, behavior: 'instant' });
        totalDelta += delta;
        requestAnimationFrame(animate);
      }
    }

    if (!continuous) { ++scrollTime; }

    requestAnimationFrame(animate);
  }

  function showIndicator(text: string) {
    if (!indicator || !indicatorText) return;
    indicatorText.textContent = text;
    indicator.classList.remove('opacity-0');
    indicator.classList.add('opacity-100');

    if (indicatorTimeout) clearTimeout(indicatorTimeout);
    indicatorTimeout = setTimeout(() => {
      indicator.classList.remove('opacity-100');
      indicator.classList.add('opacity-0');
    }, 1200);
  }

  function isHelpVisible(): boolean {
    return !helpOverlay?.classList.contains('hidden');
  }

  function toggleHelp() {
    helpOverlay?.classList.toggle('hidden');
  }

  function scrollToSection(index: number) {
    const sectionId = sections[index];
    const el = document.getElementById(sectionId);
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      showIndicator(`:${index + 1} → ${sectionId}`);
    }
  }

  function isTyping(e: KeyboardEvent): boolean {
    const tag = (e.target as HTMLElement)?.tagName;
    return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
  }

  // Key down: start continuous scroll for j/k, single actions for others
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (isTyping(e)) return;

    const key = e.key;

    // ? = toggle help
    if (key === '?') {
      e.preventDefault();
      toggleHelp();
      return;
    }

    // Escape = close help
    if (key === 'Escape' && isHelpVisible()) {
      e.preventDefault();
      toggleHelp();
      return;
    }

    if (isHelpVisible()) return;

    // j/k = Vimium smooth scroll (60px, continuous when held)
    if (key === 'j' || key === 'k') {
      e.preventDefault();
      if (e.repeat) return; // existing animation handles held key via calibration
      scrollKeyDown = key;
      smoothScroll(key === 'j' ? SCROLL_STEP : -SCROLL_STEP);
      return;
    }

    // Prevent repeat for all other keys
    if (e.repeat) return;

    // d = half page down (non-continuous, single animation)
    if (key === 'd') {
      e.preventDefault();
      smoothScroll(HALF_PAGE, false);
      showIndicator('SCROLL ↓');
      return;
    }

    // u = half page up (non-continuous, single animation)
    if (key === 'u') {
      e.preventDefault();
      smoothScroll(-HALF_PAGE, false);
      showIndicator('SCROLL ↑');
      return;
    }

    // G = go to bottom
    if (key === 'G') {
      e.preventDefault();
      window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      showIndicator(':$ → bottom');
      return;
    }

    // gg = go to top
    if (key === 'g') {
      e.preventDefault();
      if (gPressed) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        showIndicator(':0 → top');
        gPressed = false;
        if (gTimeout) clearTimeout(gTimeout);
      } else {
        gPressed = true;
        showIndicator('g...');
        gTimeout = setTimeout(() => {
          gPressed = false;
        }, 800);
      }
      return;
    }

    // 0 = about (top), 1-5 = jump to sections
    if (key === '0') {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
      showIndicator(':0 → about');
      return;
    }

    if (key >= '1' && key <= '5') {
      e.preventDefault();
      scrollToSection(parseInt(key) - 1);
      return;
    }

    // t = toggle theme
    if (key === 't') {
      e.preventDefault();
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle?.click();
      const current = document.documentElement.getAttribute('data-theme');
      showIndicator(`:colorscheme ${current}`);
      return;
    }

    gPressed = false;
  });

  // Key up: release scroll key so animation clamps and stops
  document.addEventListener('keyup', (e: KeyboardEvent) => {
    if (e.key === 'j' || e.key === 'k') {
      scrollKeyDown = null;
    }
  });

  // Stop scrolling if window loses focus
  window.addEventListener('blur', () => {
    scrollKeyDown = null;
  });

  // Click outside help to close
  helpOverlay?.addEventListener('click', (e: Event) => {
    if (e.target === helpOverlay) {
      toggleHelp();
    }
  });
</script>
