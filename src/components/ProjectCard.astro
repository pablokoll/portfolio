---
import type { ProjectDetail } from '../lib/types';

interface Props {
  project: ProjectDetail;
  index: number;
}

const { project, index } = Astro.props;

const indexStr = String(index).padStart(2, '0');
const href = `/projects/${project.id}`;
const badgeColor = project.badge === 'freelance' ? 'green'
  : project.badge === 'personal' ? 'sky'
  : project.badge === 'open-source' ? 'mauve'
  : 'muted';
---

<a href={href} class="project-card">
  <div class="project-top">
    <span class="project-index">{indexStr}</span>
    {project.badge && (
      <span class={`project-badge project-badge--${badgeColor}`}>{project.badge}</span>
    )}
  </div>

  <h3 class="project-name">{project.name}</h3>

  {project.descriptionHtml ? (
    <p class="project-description" set:html={project.descriptionHtml} />
  ) : (
    <p class="project-description">{project.description}</p>
  )}

  <div class="project-stack">
    {project.stack.map((tech) => (
      <span class="project-tag">{tech}</span>
    ))}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-surface);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: border-color var(--duration-2) var(--ease);
  }

  .project-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--pk-steel);
    transition: width var(--duration-2) var(--ease);
  }

  .project-card:hover::after {
    width: 100%;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .project-index {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 99px;
    background: transparent;
    flex-shrink: 0;
  }

  .project-badge--green {
    color: var(--pk-green);
    border: 1px solid var(--pk-green);
  }

  .project-badge--sky {
    color: var(--pk-sky);
    border: 1px solid var(--pk-sky);
  }

  .project-badge--mauve {
    color: var(--pk-mauve);
    border: 1px solid var(--pk-mauve);
  }

  .project-badge--muted {
    color: var(--fg-secondary);
    border: 1px solid var(--border);
  }

  .project-description :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }

  .project-description :global(em) {
    color: var(--pk-steel);
    font-style: normal;
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .project-description {
    font-size: 14px;
    color: var(--fg-secondary);
    line-height: 1.55;
    margin: 0 0 20px;
    flex-grow: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 3px 8px;
    border-radius: 6px;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
  }
</style>
