---
import { Image } from 'astro:assets';
import type { ProjectItem } from '../lib/types';
import Icon from './Icon.astro';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/screenshots/*.png');
const imageSrc = project.image ? images[`../assets/screenshots/${project.image}`] : null;
const resolvedImage = imageSrc ? (await imageSrc()).default : null;
---

<article class="project-card card card-hover">
  <!-- Screenshot -->
  <div class="project-image">
    {resolvedImage ? (
      <Image
        src={resolvedImage}
        alt={`${project.name} screenshot`}
        class="project-img"
        loading="lazy"
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 50vw"
      />
    ) : (
      <div class="project-img-placeholder">
        <span>[Project Screenshot]</span>
      </div>
    )}
  </div>

  <div class="project-body">
    <!-- Header: Title + Badge -->
    <header class="project-header">
      <h3 class="project-name">{project.name}</h3>
      {project.badge && (
        <span class="project-badge">{project.badge}</span>
      )}
      {project.github && !project.badge && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="project-github"
          aria-label={`View ${project.name} on GitHub`}
        >
          <Icon name="github" class="w-5 h-5" />
        </a>
      )}
    </header>

    <!-- Description -->
    <p class="project-description">{project.description}</p>

    <!-- Stack Tags -->
    <footer class="project-stack">
      {project.stack.map((tech) => (
        <span class="project-tag">{tech}</span>
      ))}
    </footer>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .project-image {
    aspect-ratio: 16 / 10;
    background: var(--bg-surface);
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-size: 12px;
    color: var(--fg-muted);
  }

  .project-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .project-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 99px;
    background: var(--bg-surface);
    color: var(--fg-secondary);
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .project-github {
    color: var(--fg-muted);
    transition: color var(--duration-2) var(--ease);
  }

  .project-github:hover {
    color: var(--fg);
  }

  .project-description {
    font-size: 13px;
    color: var(--fg-secondary);
    line-height: 1.55;
    margin: 0 0 14px;
    flex-grow: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 3px 8px;
    border-radius: 6px;
    background: var(--bg-surface);
    color: var(--fg);
    border: 1px solid var(--border);
  }
</style>
