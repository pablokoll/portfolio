---
import type { LearningItem } from '../lib/types';

interface Props {
  items: LearningItem[];
}

const { items } = Astro.props;

const nodePositions: Record<string, { x: number; y: number }> = {
  learning_golang:   { x: 150, y: 120 },
  mastering_vim:     { x: 420, y: 90  },
  obsidian_notes:    { x: 120, y: 300 },
  ai_tools_mastery:  { x: 430, y: 280 },
};

const nodeLabels: Record<string, { top: string; bottom: string }> = {
  learning_golang:  { top: 'learning', bottom: 'Go'       },
  mastering_vim:    { top: 'mastering', bottom: 'Vim'     },
  obsidian_notes:   { top: 'mastering', bottom: 'Obsidian'},
  ai_tools_mastery: { top: 'mastering', bottom: 'AI Tools'},
};

const decorativeNodes = [
  { x: 60,  y: 80  },
  { x: 230, y: 55  },
  { x: 310, y: 160 },
  { x: 500, y: 170 },
  { x: 540, y: 60  },
  { x: 270, y: 340 },
  { x: 370, y: 370 },
  { x: 510, y: 340 },
  { x: 75,  y: 210 },
];

const lines: [string, string][] = [
  ['learning_golang',  'mastering_vim'    ],
  ['learning_golang',  'obsidian_notes'   ],
  ['mastering_vim',    'ai_tools_mastery' ],
  ['obsidian_notes',   'ai_tools_mastery' ],
  ['learning_golang',  'd0'               ],
  ['learning_golang',  'd1'               ],
  ['mastering_vim',    'd4'               ],
  ['mastering_vim',    'd3'               ],
  ['obsidian_notes',   'd8'               ],
  ['obsidian_notes',   'd5'               ],
  ['ai_tools_mastery','d7'               ],
  ['ai_tools_mastery','d6'               ],
  ['d1',               'd2'               ],
  ['d2',               'd3'               ],
];

function getCoords(key: string): { x: number; y: number } | undefined {
  if (key.startsWith('d')) {
    return decorativeNodes[parseInt(key.slice(1))];
  }
  return nodePositions[key];
}

const NODE_W = 124;
const NODE_H = 56;
---

<div class="constellation-wrap">
  <svg
    viewBox="0 0 600 400"
    xmlns="http://www.w3.org/2000/svg"
    class="constellation-svg"
    aria-hidden="true"
  >
    <!-- Lines -->
    {lines.map(([a, b]) => {
      const ca = getCoords(a);
      const cb = getCoords(b);
      if (!ca || !cb) return null;
      return (
        <line
          x1={ca.x} y1={ca.y}
          x2={cb.x} y2={cb.y}
          stroke="var(--border)"
          stroke-width="1"
          opacity="0.4"
        />
      );
    })}

    <!-- Decorative nodes -->
    {decorativeNodes.map((n) => (
      <circle cx={n.x} cy={n.y} r="3" fill="var(--fg-muted)" opacity="0.5" />
    ))}

    <!-- Main nodes -->
    {items.map((item) => {
      const pos = nodePositions[item.name];
      const label = nodeLabels[item.name];
      if (!pos || !label) return null;
      const color = `var(--${item.iconColor})`;
      const shortDesc = item.description.length > 110
        ? item.description.slice(0, 107) + '...'
        : item.description;
      return (
        <g
          class="constellation-node"
          data-name={item.name}
          data-desc={shortDesc}
          data-progress={item.progressPercent}
          data-progress-label={item.progressComment}
          data-color={`var(--${item.iconColor})`}
          tabindex="0"
          role="button"
          aria-label={`${label.top} ${label.bottom}`}
          transform={`translate(${pos.x - NODE_W / 2}, ${pos.y - NODE_H / 2})`}
        >
          <rect
            class="node-rect"
            width={NODE_W}
            height={NODE_H}
            rx="8"
            fill="var(--bg-surface)"
            stroke={color}
            stroke-opacity="0.5"
            stroke-width="1"
          />
          <text
            class="node-label-top"
            x={NODE_W / 2}
            y="18"
            text-anchor="middle"
            font-family="var(--font-mono)"
            font-size="10"
            fill="var(--fg-muted)"
          >{label.top}</text>
          <text
            class="node-label-bottom"
            x={NODE_W / 2}
            y="38"
            text-anchor="middle"
            font-family="var(--font-mono)"
            font-size="15"
            font-weight="600"
            fill={color}
          >{label.bottom}</text>
        </g>
      );
    })}
  </svg>
</div>

<script>
  const tooltip = document.createElement('div');
  tooltip.className = 'constellation-tooltip';
  tooltip.setAttribute('aria-hidden', 'true');
  tooltip.innerHTML = `
    <div class="node-tooltip-top"></div>
    <div class="node-tooltip-bottom"></div>
    <div class="node-tooltip-divider"></div>
    <p class="node-tooltip-desc"></p>
    <span class="node-tooltip-progress-label"></span>
    <div class="node-tooltip-bar-track"><div class="node-tooltip-bar-fill"></div></div>
  `;
  document.body.appendChild(tooltip);

  const nodes = document.querySelectorAll<SVGGElement>('.constellation-node');

  function showTooltip(node: SVGGElement) {
    const desc = node.dataset.desc ?? '';
    const rawProgress = parseInt(node.dataset.progress ?? '0');
    const progress = isNaN(rawProgress) ? 0 : rawProgress;
    const progressLabel = node.dataset.progressLabel ?? '';
    const color = node.dataset.color ?? 'var(--pk-sky)';

    const rect = node.getBoundingClientRect();

    const texts = node.querySelectorAll('text');
    const topLabel = texts[0]?.textContent ?? '';
    const bottomLabel = texts[1]?.textContent ?? '';

    tooltip.querySelector('.node-tooltip-top')!.textContent = topLabel;
    const bottomEl = tooltip.querySelector('.node-tooltip-bottom') as HTMLElement;
    bottomEl.textContent = bottomLabel;
    bottomEl.style.color = color;
    tooltip.querySelector('.node-tooltip-desc')!.textContent = desc;
    tooltip.querySelector('.node-tooltip-progress-label')!.textContent = progressLabel;
    const fill = tooltip.querySelector('.node-tooltip-bar-fill') as HTMLElement;
    fill.style.width = `${progress}%`;
    fill.style.background = color;

    const tooltipW = 200;
    let left = rect.left + rect.width / 2 - tooltipW / 2;

    tooltip.style.width = `${tooltipW}px`;
    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${rect.bottom + 8}px`;
    tooltip.style.borderColor = color;
    tooltip.setAttribute('aria-hidden', 'false');
    tooltip.className = 'constellation-tooltip visible';

    requestAnimationFrame(() => {
      const tRect = tooltip.getBoundingClientRect();
      if (tRect.bottom > window.innerHeight - 16) {
        tooltip.style.top = `${rect.top - tRect.height - 8}px`;
      }
      if (tRect.right > window.innerWidth - 8) {
        tooltip.style.left = `${window.innerWidth - tooltipW - 8}px`;
      }
      if (tRect.left < 8) {
        tooltip.style.left = '8px';
      }
    });
  }

  function hideTooltip() {
    tooltip.className = 'constellation-tooltip';
    tooltip.setAttribute('aria-hidden', 'true');
  }

  nodes.forEach((node) => {
    node.addEventListener('mouseenter', () => showTooltip(node));
    node.addEventListener('mouseleave', hideTooltip);
    node.addEventListener('focus', () => showTooltip(node));
    node.addEventListener('blur', hideTooltip);
    node.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        showTooltip(node);
      }
    });
  });
</script>

<style>
  .constellation-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .constellation-svg {
    width: 100%;
    height: auto;
  }
  .constellation-node {
    cursor: pointer;
  }

  :global(.constellation-tooltip) {
    position: fixed;
    z-index: 100;
    pointer-events: none;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
    box-shadow: 0 4px 24px rgba(0,0,0,0.18);
  }

  :global(.constellation-tooltip.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.node-tooltip-top) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }

  :global(.node-tooltip-bottom) {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  :global(.node-tooltip-divider) {
    height: 1px;
    background: var(--border);
    margin-bottom: 8px;
  }

  :global(.node-tooltip-desc) {
    font-size: 12px;
    line-height: 1.5;
    color: var(--fg-secondary);
    margin: 0 0 10px;
  }

  :global(.node-tooltip-progress-label) {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-muted);
    font-style: italic;
    margin-bottom: 5px;
  }

  :global(.node-tooltip-bar-track) {
    height: 5px;
    background: var(--bg-base);
    border-radius: 99px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  :global(.node-tooltip-bar-fill) {
    height: 100%;
    border-radius: 99px;
    transition: width 300ms ease;
  }
</style>
