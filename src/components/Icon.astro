const path = icons[name] || icons['external-link'];
const isFillIcon = ['github', 'linkedin', 'twitter'].includes(name);
---

<svg
  class={className}
  fill={isFillIcon ? 'currentColor' : 'none'}
  viewBox={isFillIcon ? '0 0 24 24' : '0 0 24 24'}
  stroke={isFillIcon ? 'none' : 'currentColor'}
  stroke-width={isFillIcon ? '0' : '2'}
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <path d={path} />
</svg>
