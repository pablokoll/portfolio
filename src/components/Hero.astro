---
import type { Hero as HeroType } from '../lib/types';

interface Props {
  data: HeroType;
}

const { data } = Astro.props;
---

<section class="min-h-screen flex flex-col justify-center px-6 md:px-24 lg:px-32 py-20">
  <div class="max-w-6xl mx-auto w-full">
    <!-- Terminal prompt -->
    <p class="text-ctp-blue font-medium text-base md:text-lg mb-4">
      {data.prompt}
    </p>

    <!-- Headline -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-semibold text-ctp-text mb-6">
      {data.headline}
    </h1>

    <!-- Subline -->
    <p class="text-ctp-overlay0 text-lg md:text-xl mb-10 max-w-2xl">
      {data.subline}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-3">
      {data.cta.primary.href.startsWith('#') ? (
        <button
          type="button"
          data-scroll-to={data.cta.primary.href.replace('#', '')}
          class="px-6 py-3 bg-ctp-blue text-ctp-base font-medium text-sm rounded hover:opacity-90 transition-opacity cursor-pointer"
        >
          {data.cta.primary.text}
        </button>
      ) : (
        <a
          href={data.cta.primary.href}
          class="px-6 py-3 bg-ctp-blue text-ctp-base font-medium text-sm rounded hover:opacity-90 transition-opacity"
        >
          {data.cta.primary.text}
        </a>
      )}
      {data.cta.secondary.href.startsWith('#') ? (
        <button
          type="button"
          data-scroll-to={data.cta.secondary.href.replace('#', '')}
          class="px-6 py-3 bg-ctp-surface0 text-ctp-overlay2 font-medium text-sm rounded hover:bg-ctp-surface1 transition-colors cursor-pointer"
        >
          {data.cta.secondary.text}
        </button>
      ) : (
        <a
          href={data.cta.secondary.href}
          class="px-6 py-3 bg-ctp-surface0 text-ctp-overlay2 font-medium text-sm rounded hover:bg-ctp-surface1 transition-colors"
        >
          {data.cta.secondary.text}
        </a>
      )}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-scroll-to]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.scrollTo!);
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
