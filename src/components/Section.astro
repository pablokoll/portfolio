---
interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  index?: number;
  class?: string;
  titleHtml?: string;
  dividerLabel?: string;
}

const { id, title, subtitle, index, class: className = '', titleHtml, dividerLabel } = Astro.props;
const indexStr = index !== undefined ? String(index).padStart(2, '0') : undefined;
---

<section id={id} class:list={['section', className]}>
  {indexStr && !className.includes('section--first') && (
    <div class="section-divider" aria-hidden="true">
      <span class="section-divider-label">{indexStr} — {dividerLabel ?? title}</span>
    </div>
  )}
  <div class="section-inner">
    <!-- Section Header -->
    <header class="section-header">
      {titleHtml
        ? <h2 class="section-title" set:html={titleHtml} />
        : <h2 class="section-title">{title}</h2>
      }
      {subtitle && <p class="section-subtitle">{subtitle}</p>}
    </header>

    <!-- Section Content -->
    <slot />
  </div>
</section>

<style>
  .section {
    padding: 64px 0;
  }

  .section--first {
    padding-top: 0;
  }

  .section-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 64px;
  }

  .section-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 64px;
    margin-bottom: 48px;
    margin-top: -32px;
  }

  .section-divider::before {
    content: '';
    position: absolute;
    left: 64px;
    right: 64px;
    top: 50%;
    height: 1px;
    background: var(--border);
  }

  .section-divider-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--bg);
    padding: 0 12px;
    position: relative;
    z-index: 1;
  }

  .section-header {
    margin-bottom: 32px;
  }

  .section-title {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin: 0;
  }

  .section-subtitle {
    font-size: 14px;
    color: var(--fg-muted);
    font-style: italic;
    margin: 6px 0 0;
  }

  @media (max-width: 720px) {
    .section {
      padding: 48px 0;
    }

    .section-inner {
      padding: 0 24px;
    }

    .section-divider {
      padding: 0 24px;
    }

    .section-divider::before {
      left: 24px;
      right: 24px;
    }
  }
</style>
