---
import type { SkillCategory } from '../lib/types';
import Icon from './Icon.astro';

interface Props {
  skill: SkillCategory;
}

const { skill } = Astro.props;

// Map pk-* token name to the CSS custom property
const iconColorVar = `var(--${skill.iconColor})`;
---

<article class="skill-card card card-hover">
  <!-- Icon -->
  <div class="skill-icon-wrap" style={`--icon-color: ${iconColorVar}`}>
    <Icon name={skill.icon} class="skill-icon" />
  </div>

  <!-- Title -->
  <h3 class="skill-name">{skill.name}</h3>

  <!-- Tech list -->
  <p class="skill-description">{skill.description}</p>
</article>

<style>
  .skill-card {
    padding: 20px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .skill-icon-wrap {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--bg-surface);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    color: var(--icon-color, var(--pk-sky));
  }

  .skill-icon {
    width: 16px;
    height: 16px;
  }

  .skill-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 8px;
  }

  .skill-description {
    font-size: 13px;
    color: var(--fg-secondary);
    line-height: 1.55;
    margin: 0;
    flex-grow: 1;
  }
</style>
