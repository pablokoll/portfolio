---
import '../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro";
import CustomCursor from '../components/CustomCursor.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  url?: string;
}

const { title, description, ogImage = '/og-image.png', url } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="latte">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Software Developer, Backend Developer, Full Stack Developer, Node.js, TypeScript, JavaScript, Python, React, Vue.js, Next.js, Astro, NestJS, Express.js, API Design, REST, GraphQL, SOAP, eCommerce, Shopify, SFCC, Salesforce Commerce Cloud, PostgreSQL, MySQL, MongoDB, Redis, Docker, AWS, Git, CI/CD, Linux, Puppeteer, Go, Golang, Laravel, PHP" />
    <meta name="author" content="Pablo Koll" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {url && <meta property="og:url" content={url} />}
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Canonical URL -->
    {url && <link rel="canonical" href={url} />}

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "name": "Pablo Koll",
        "jobTitle": "Software Developer",
        "url": url || "https://pablokoll.com",
        "sameAs": [
          "https://github.com/pablokoll",
          "https://linkedin.com/in/pablo-koll"
        ],
        "knowsAbout": [
          "Node.js", "TypeScript", "JavaScript", "Python", "React", "Vue.js",
          "NestJS", "Express.js", "PostgreSQL", "MongoDB", "Redis", "Docker",
          "AWS", "GraphQL", "REST API", "Shopify", "Salesforce Commerce Cloud",
          "Git", "CI/CD", "Linux", "Go"
        ],
        "description": description
      }
    })} />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('pk-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'mocha' : 'latte');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <SpeedInsights />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--bg); color: var(--fg);">
    <CustomCursor />
    <slot />
  </body>
</html>
